{
  "info": {
    "name": "Student Management System API",
    "_postman_id": "b6a1f5b0-6e5e-4e2a-9d0a-student-mgmt-api",
    "description": "JSON REST API for the Cloud-Native Student Management System. Login first (Auth > Login) -- Postman's cookie jar keeps the session cookie for the rest of the collection automatically. Set the 'base_url' collection variable to your running instance (defaults to http://localhost:5000).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:5000", "type": "string" },
    { "key": "student_id", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": { "raw": "{{base_url}}/health", "host": ["{{base_url}}"], "path": ["health"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status 200', function () { pm.response.to.have.status(200); });",
              "pm.test('status ok', function () { pm.expect(pm.response.json().status).to.eql('ok'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (correct credentials)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/login", "host": ["{{base_url}}"], "path": ["api", "login"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('login successful message', function () { pm.expect(pm.response.json().message).to.eql('login successful'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Login (wrong password)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"wrong-password\"\n}"
            },
            "url": { "raw": "{{base_url}}/api/login", "host": ["{{base_url}}"], "path": ["api", "login"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 401', function () { pm.response.to.have.status(401); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Students",
      "item": [
        {
          "name": "List Students",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/students", "host": ["{{base_url}}"], "path": ["api", "students"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('response is an array', function () { pm.expect(pm.response.json()).to.be.an('array'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Student",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Postman Test Student\",\n  \"email\": \"postman.student@example.com\",\n  \"phone\": \"9990001111\",\n  \"dept_id\": 1,\n  \"year\": 2,\n  \"cgpa\": 7.5\n}"
            },
            "url": { "raw": "{{base_url}}/api/students", "host": ["{{base_url}}"], "path": ["api", "students"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 201', function () { pm.response.to.have.status(201); });",
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('student_id', json.student_id);",
                  "pm.test('has student_id', function () { pm.expect(json.student_id).to.be.a('number'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Student (duplicate email -> 409)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Duplicate\",\n  \"email\": \"postman.student@example.com\",\n  \"dept_id\": 1,\n  \"year\": 1\n}"
            },
            "url": { "raw": "{{base_url}}/api/students", "host": ["{{base_url}}"], "path": ["api", "students"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 409', function () { pm.response.to.have.status(409); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Student by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/students/{{student_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "students", "{{student_id}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Student by ID (not found -> 404)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/students/999999",
              "host": ["{{base_url}}"],
              "path": ["api", "students", "999999"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 404', function () { pm.response.to.have.status(404); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Student",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Postman Test Student Updated\",\n  \"email\": \"postman.student@example.com\",\n  \"phone\": \"9990001111\",\n  \"dept_id\": 2,\n  \"year\": 3,\n  \"cgpa\": 8.1\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/students/{{student_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "students", "{{student_id}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('name updated', function () { pm.expect(pm.response.json().full_name).to.eql('Postman Test Student Updated'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Search Students",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/students/search?q=nair",
              "host": ["{{base_url}}"],
              "path": ["api", "students", "search"],
              "query": [{ "key": "q", "value": "nair" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete Student",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/api/students/{{student_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "students", "{{student_id}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 200', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Student by ID (after delete -> 404)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/students/{{student_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "students", "{{student_id}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status 404', function () { pm.response.to.have.status(404); });"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Logout",
      "request": {
        "method": "POST",
        "url": { "raw": "{{base_url}}/api/logout", "host": ["{{base_url}}"], "path": ["api", "logout"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status 200', function () { pm.response.to.have.status(200); });"
            ]
          }
        }
      ]
    },
    {
      "name": "List Students (after logout -> 401)",
      "request": {
        "method": "GET",
        "url": { "raw": "{{base_url}}/api/students", "host": ["{{base_url}}"], "path": ["api", "students"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status 401', function () { pm.response.to.have.status(401); });"
            ]
          }
        }
      ]
    }
  ]
}