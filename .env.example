# Copy this file to .env and fill in real values. .env is gitignored — never commit it.

# --- Docker Compose ---
# The project folder name has spaces ("cloud cicd project"), which Docker Compose would
# otherwise turn into a messy default project/network name. Pinning it keeps
# `docker compose` container/network names clean and predictable.
COMPOSE_PROJECT_NAME=student-mgmt

# --- Flask ---
FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-secret-in-production

# --- MySQL connection (used by the Flask app) ---
DB_HOST=db
DB_PORT=3306
DB_NAME=student_mgmt
DB_USER=app_user
DB_PASSWORD=app_password

# --- MySQL container bootstrap (used by the mysql:8.0 image itself) ---
MYSQL_ROOT_PASSWORD=root_password
MYSQL_DATABASE=student_mgmt
MYSQL_USER=app_user
MYSQL_PASSWORD=app_password